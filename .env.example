# ============================================
# The Gauntlet — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# --- Required ---
ANTHROPIC_API_KEY=

# --- Optional: Web Search (for agents that need it) ---
BRAVE_SEARCH_API_KEY=

# --- Optional: Gateway port (default 19701) ---
GAUNTLET_PORT=19701
